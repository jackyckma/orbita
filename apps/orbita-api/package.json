    "@orbita/auth": "workspace:*",
    "@orbita/credentials": "workspace:*",
    "@orbita/harness": "workspace:*",
    "@orbita/memory": "workspace:*",
    "@orbita/platform": "workspace:*",
    "@orbita/profiles": "workspace:*",
    "@orbita/scheduler": "workspace:*",
    "@orbita/sessions": "workspace:*",
    "@orbita/trajectory": "workspace:*",
    "@orbita/waitlist": "workspace:*",
    "hono": "^4.7.11",
    "postgres": "^3.4.7",
    "zod": "^3.25.56"
  },
  "devDependencies": {
    "tsx": "^4.19.4"
  }
