# Server (use 3001 if 3000 is occupied locally)
PORT=3000
HOST=127.0.0.1
NODE_ENV=development

# Database (Postgres + pgvector)
DATABASE_URL=postgresql://orbita:orbita@localhost:5432/orbita

# Admin bootstrap — used to protect /v1/admin/* until full key management exists
ORBITA_ADMIN_TOKEN=change-me-in-production

# Credential vault encryption key (min 16 chars)
ORBITA_SECRETS_KEY=change-me-to-a-long-random-secret

# AI providers — primary: MiniMax, fallback: Anthropic
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-M3
MINIMAX_BASE_URL=https://api.minimax.io/v1

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Memory embeddings (MiniMax embo-01, 1024-dim pgvector)
EMBEDDING_MODEL=embo-01
EMBEDDING_DIMENSIONS=1024
MEMORY_TOP_K=8

# HTTP tools — optional domain allow-list (comma-separated hostnames); empty = any HTTPS host
ORBITA_HTTP_ALLOWED_DOMAINS=
ORBITA_HTTP_TIMEOUT_MS=30000
# web_search backend (default: self-hosted SearXNG)
ORBITA_WEB_SEARCH_PROVIDER=searxng
ORBITA_SEARXNG_BASE_URL=

# Public base URL for device-flow links (defaults to http://127.0.0.1:PORT)
ORBITA_PUBLIC_BASE_URL=

# Docker sandbox — set to 1 to expose docker_echo tool (requires Docker socket)
ORBITA_SANDBOX_DOCKER=

# Cursor API key for /orchestrate multi-agent development (never commit real values)
CURSOR_API_KEY=

# Cloudflare (Workers deploy for apps/orbita-web, DNS scripts)
CLOUDFLARE_API_TOKEN=

# Waitlist — default waitlist@get-orbita.com (requires Cloudflare Email Routing forward)
# Waitlist (Phase 1) — comma-separated CORS origins for POST /v1/waitlist
ORBITA_WAITLIST_ALLOWED_ORIGINS=https://get-orbita.com,https://www.get-orbita.com
# Optional default client_id when admin approves waitlist (else waitlist-{entry_id prefix})
ORBITA_WAITLIST_INVITE_CLIENT_ID=
# Optional: email for waitlist invite E2E (scripts/waitlist-invite-e2e-prod.sh); Gmail +alias supported
ORBITA_E2E_INVITE_EMAIL=

# Rate limiting — requests per minute per API key (fixed window)
RATE_LIMIT_PER_MINUTE=120

# W17 daily quotas per client_id (rolling 24h). 0 = unlimited.
# Hosted Phase 1 suggestion: ORBITA_QUOTA_SESSIONS_PER_DAY=50 ORBITA_QUOTA_MESSAGES_PER_DAY=200
ORBITA_QUOTA_SESSIONS_PER_DAY=0
ORBITA_QUOTA_MESSAGES_PER_DAY=0

# Outbound sender identity for this deployment (see docs/instance-email.md)
ORBITA_INSTANCE_FROM_EMAIL=

# Zeabur Email (ZSend) — outbound via agent http_post (see docs/instance-email.md)
ZEABUR_ZSEND_API_KEY=

# Inbound email adapter (Cloudflare Email Worker → POST /v1/inbound/email)
ORBITA_INBOUND_EMAIL_TOKEN=
ORBITA_INBOUND_CLIENT_ID=orbita-instance
ORBITA_INBOUND_AGENT_PROFILE=marketing
