# Server (use 3001 if 3000 is occupied locally)
PORT=3000
HOST=127.0.0.1
NODE_ENV=development

# Database (Postgres + pgvector)
DATABASE_URL=postgresql://orbita:orbita@localhost:5432/orbita

# Admin bootstrap — used to protect /v1/admin/* until full key management exists
ORBITA_ADMIN_TOKEN=change-me-in-production

# Credential vault encryption key (min 16 chars)
ORBITA_SECRETS_KEY=change-me-to-a-long-random-secret

# AI providers — primary: MiniMax, fallback: Anthropic
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-M3
MINIMAX_BASE_URL=https://api.minimax.io/v1

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Memory embeddings (MiniMax embo-01, 1024-dim pgvector)
EMBEDDING_MODEL=embo-01
EMBEDDING_DIMENSIONS=1024
MEMORY_TOP_K=8

# Cursor API key for /orchestrate multi-agent development (never commit real values)
CURSOR_API_KEY=
